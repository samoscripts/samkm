<div class="mt-6">
    <h3 class="text-xl font-semibold mb-4">Mileage Information</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="mb-4">
            <label for="date_start" class="block text-gray-700">Miesiąc początkowy</label>
            <input type="text" id="date_start" name="date_start" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm flatpickr" readonly>
        </div>
        <div class="mb-4">
            <label for="date_end" class="block text-gray-700">Miesiąc końcowy</label>
            <input type="text" id="date_end" name="date_end" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm flatpickr" readonly>
        </div>
        <div class="mb-4">
            <label for="mileage_start" class="block text-gray-700">Stan licznika na początku pierwszego miesiąca</label>
            <input type="text" id="mileage_start" name="mileage_start" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
        <div class="mb-4">
            <label for="mileage_end" class="block text-gray-700">Stan licznika na koniec ostatniego miesiąca</label>
            <input type="text" id="mileage_end" name="mileage_end" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
        <div class="mb-4">
            <label for="tolerance_max" class="block text-gray-700">Maksymalny przebieg w danym miesiącu (+/- tolerancja)</label>
            <input type="text" id="tolerance_max" name="tolerance_max" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
        <div class="mb-4">
            <label for="tolerance" class="block text-gray-700">Tolerancja dla maksymalnego przebiegu</label>
            <input type="text" id="tolerance" name="tolerance" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
    </div>
</div>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        flatpickr(".flatpickr", {
            locale: "pl",
            plugins: [
                new monthSelectPlugin({
                    shorthand: true, //defaults to false
                    dateFormat: "Y-m", //defaults to "F Y"
                    altFormat: "F Y", //defaults to "F Y"
                    theme: "light" // defaults to "light"
                })
            ]
        });
    });
</script>