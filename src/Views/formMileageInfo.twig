<div class="mt-6">
    <h3 class="text-xl font-semibold mb-4">Mileage Information</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="mb-4">
            <label for="date_start" class="block text-gray-700">Date Start</label>
            <input type="text" id="date_start" name="date_start" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
        <div class="mb-4">
            <label for="date_end" class="block text-gray-700">Date End</label>
            <input type="text" id="date_end" name="date_end" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
        <div class="mb-4">
            <label for="mileage_start" class="block text-gray-700">Mileage Start</label>
            <input type="text" id="mileage_start" name="mileage_start" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
        <div class="mb-4">
            <label for="mileage_end" class="block text-gray-700">Mileage End</label>
            <input type="text" id="mileage_end" name="mileage_end" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
        <div class="mb-4">
            <label for="tolerance_max" class="block text-gray-700">Tolerance Max</label>
            <input type="text" id="tolerance_max" name="tolerance_max" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
        <div class="mb-4">
            <label for="tolerance" class="block text-gray-700">Tolerance</label>
            <input type="text" id="tolerance" name="tolerance" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
    </div>
</div>