<div class="mt-6">
    <h3 class="text-xl font-semibold mb-4">Dane pojazdu</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="mb-4">
            <label for="vehicle_brand" class="block text-gray-700">Marka pojazdu</label>
            <input type="text" id="vehicle_brand" name="vehicle_brand" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
        <div class="mb-4">
            <label for="vehicle_model" class="block text-gray-700">Model pojazdu</label>
            <input type="text" id="vehicle_model" name="vehicle_model" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
        <div class="mb-4">
            <label for="vehicle_year" class="block text-gray-700">Rok produkcji</label>
            <input type="text" id="vehicle_year" name="vehicle_year" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
        <div class="mb-4">
            <label for="registration_number" class="block text-gray-700">Numer rejestracyjny</label>
            <input type="text" id="registration_number" name="registration_number" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
        <div class="mb-4">
            <label for="vin" class="block text-gray-700">VIN</label>
            <input type="text" id="vin" name="vin" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
        <div class="mb-4">
            <label for="engine_capacity" class="block text-gray-700">Pojemność silnika</label>
            <input type="text" id="engine_capacity" name="engine_capacity" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm">
        </div>
    </div>
</div>